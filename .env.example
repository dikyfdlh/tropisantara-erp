# Database --- pakai SQLite untuk dev cepat
DATABASE_URL="file:./dev.db"

# Untuk produksi (PostgreSQL), gunakan format:
# DATABASE_URL="postgresql://user:password@host:5432/provisio_erp?schema=public"

# NextAuth (Auth.js v5) --- WAJIB
# Generate dengan: openssl rand -base64 32  (atau pakai online generator)
AUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
AUTH_TRUST_HOST=true

# URL aplikasi (untuk callback / cookies)
NEXTAUTH_URL="http://localhost:3000"
